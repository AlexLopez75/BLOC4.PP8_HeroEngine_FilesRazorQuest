@page
@model HeroEngine.Web.Pages.Combat.CombatModel
@{
    ViewData["Title"] = "Battle Sim";
}

<div class="text-center mb-4">
    <h1 class="display-4 text-danger fw-bold">BATTLE SIMULATION</h1>
</div>

<form method="post" class="card p-4 shadow mb-5 border-danger bg-dark text-light">
    <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>
    
    <div class="row align-items-center">
        <div class="col-md-5">
            <h4 class="text-info fw-bold mb-3 text-center">Party (@Model.AvailableHeroes.Count)</h4>
            <ul class="list-group list-group-flush rounded">
                @foreach (var hero in Model.AvailableHeroes)
                {
                    <li class="list-group-item bg-secondary text-white border-dark">
                        <strong>@hero.Name</strong> 
                        <span class="badge bg-info text-dark float-end">Lvl @hero.Level</span>
                        <br>
                        <small class="text-light">Classe: @hero.GetType().Name | HP: @hero.MaxHp</small>
                    </li>
                }
            </ul>
        </div>

        <div class="col-md-2 text-center">
            <h1 class="text-danger fw-bold m-0 mt-3" style="font-size: 3rem;">VS</h1>
        </div>
        
        <div class="col-md-5 text-center">
            <h4 class="text-danger fw-bold mb-3">The Enemy</h4>
            <div class="card bg-danger text-white border-0 shadow">
                <div class="card-body py-5">
                    <h3 class="card-title m-0 fw-bold">🐛 PRIMORDIAL BUG</h3>
                    <p class="small m-0 mt-2">HP: Unknown</p>
                </div>
            </div>
        </div>
    </div>
    
    <button type="submit" class="btn btn-outline-danger btn-lg mt-4 w-100 fw-bold">START BATTLE</button>
</form>

@if (Model.BattleLogs.Count > 0)
{
    <div class="card bg-black text-success border-secondary shadow">
        <div class="card-header bg-secondary text-white fw-bold">
            📜 Battle Log
        </div>
        <div class="card-body font-monospace" style="max-height: 500px; overflow-y: auto;">
            @foreach (var log in Model.BattleLogs)
            {
                if (log.Contains("THE HEROES WIN"))
                {
                    <h4 class="text-info mt-3 fw-bold">@log</h4>
                }
                else if (log.Contains("THE PRIMORDIAL BUG WINS"))
                {
                    <h4 class="text-danger mt-3 fw-bold">@log</h4>
                }
                else if (log.Contains("BATTLE LOG - Round"))
                {
                    <h5 class="text-warning mt-4 mb-2 border-bottom border-warning pb-1">@log</h5>
                }
                else if (log.Contains("[SYSTEM]"))
                {
                    <p class="mb-1 text-info">@log</p>
                }
                else
                {
                    <p class="mb-1" style="font-size: 0.95rem;">@log</p>
                }
            }
        </div>
    </div>
}