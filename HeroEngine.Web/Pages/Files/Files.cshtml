@page
@model HeroEngine.Web.Pages.Files.FilesModel
@{
    ViewData["Title"] = "Files";
}

<div class="text-center mb-4">
    <h1 class="display-4 fw-bold">🗄️ File Manager</h1>
    <p class="lead">Download the registers of your battles, your heroes and their abilities, battle statistics and game config.</p>
</div>

<div class="card p-5 shadow border-0 text-center mb-4">
    @if (Model.LogExists)
    {
        <div class="alert alert-success mb-4 text-start">
            <h4 class="alert-heading fw-bold">✅ BattleLog available!</h4>
            <p class="mb-0">The system has detected a battle log ready for download.</p>
        </div>
        
        <form method="post" asp-page-handler="DownloadLog">
            <button type="submit" class="btn btn-primary btn-lg fw-bold px-5 py-3">
                📥 Download BattleLog.txt
            </button>
        </form>
    }
    else
    {
        <div class="alert alert-warning mb-0 text-start">
            <h4 class="alert-heading fw-bold">⚠️ There isn't any battle log available</h4>
            <p class="mb-0">No battles have been played yet or the file has not been generated.</p>
        </div>
    }
</div>

<div class="card p-4 shadow border-0 text-center">
    <h3 class="fw-bold">Heroes JSON</h3>
    <p>Download the current state of all heroes in JSON format.</p>
    
    <div>
        <a asp-page-handler="DownloadJson" class="btn btn-dark fw-bold px-4 py-2">
            📥 Download Heroes (JSON)
        </a>
    </div>
</div>

<div class="card p-4 shadow border-0 text-center mt-4">
    <h3 class="fw-bold">Combat Statistics (CSV)</h3>
    <p>Download the historical combat statistics or view the latest 10 matches.</p>
    
    @if (Model.CsvExists)
    {
        <form method="post" asp-page-handler="DownloadCsv" class="mb-4">
            <button type="submit" class="btn btn-success fw-bold px-4 py-2">
                📊 Download combat_stats.csv
            </button>
        </form>

        <h5 class="text-start text-success border-bottom border-success pb-2">Last 10 Combats</h5>
        <div class="table-responsive">
            <table class="table table-dark table-striped table-hover mt-3 text-start">
                <thead>
                    <tr>
                        <th>Date</th>
                        <th>Heroes</th>
                        <th>Enemies</th>
                        <th>Result</th>
                        <th>Rounds</th>
                        <th>Damage</th>
                        <th>MVP</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var combat in Model.LastCombats)
                    {
                        <tr>
                            <td>@combat.Date.ToString("g")</td>
                            <td>@combat.ParticipatingHeroes</td>
                            <td>@combat.Enemies</td>
                            <td>
                                <span class="badge @(combat.Result == "Victoria" ? "bg-primary" : "bg-danger")">
                                    @combat.Result
                                </span>
                            </td>
                            <td>@combat.TotalRounds</td>
                            <td>@combat.TotalDamageDealt</td>
                            <td>@combat.MostEffectiveHero</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="alert alert-secondary">
            No combat statistics recorded yet. Play a simulation first!
        </div>
    }
</div>

<div class="card mt-4">
    <div class="card-header bg-dark text-white">
        <h5>Configuración del Juego (XML)</h5>
    </div>
    <div class="card-body">
        <form method="post" asp-page-handler="SaveConfig">
            <div class="row">
                <div class="col-md-3 mb-3">
                    <label class="form-label">Level Up Stats Multiplier</label>
                    <input type="number" step="0.01" class="form-control" asp-for="CurrentConfig.LevelMultiplier" />
                </div>
                <div class="col-md-3 mb-3">
                    <label class="form-label">Critical Hit Chance</label>
                    <input type="number" step="0.01" class="form-control" asp-for="CurrentConfig.CriticalHitChance" />
                </div>
                <div class="col-md-3 mb-3">
                    <label class="form-label">Max Combat Rounds</label>
                    <input type="number" class="form-control" asp-for="CurrentConfig.MaxCombatRounds" />
                </div>
                <div class="col-md-3 mb-3">
                    <label class="form-label">Max Heroes</label>
                    <input type="number" class="form-control" asp-for="CurrentConfig.MaxHeroesPerBattle" />
                </div>
            </div>
            <button type="submit" class="btn btn-success">Guardar Configuración</button>
        </form>
    </div>
</div>