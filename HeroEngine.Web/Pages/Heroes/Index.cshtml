@page 
@model HeroEngine.Web.Pages.Heroes.IndexModel
@{
    ViewData["Title"] = "Your Heroes";
}

<div class="d-flex justify-content-between align-items-center">
    <h1>Your Heroes</h1>
    <a asp-page="/Heroes/Create" class="btn btn-success">New Hero</a>
</div>

<table class="table table-striped mt-4">
    <thead class="table-dark">
        <tr>
            <th>Name</th>
            <th>Class</th>
            <th>Level</th>
            <th>HP</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var hero in Model.HeroList)
        {
            <tr>
                <td>@hero.Name</td>
                <td>@hero.GetType().Name</td>
                <td>@hero.Level</td>
                <td>@hero.MaxHp</td>
                <td>
                    <a asp-page="/Heroes/Detail" asp-route-name="@hero.Name" class="btn btn-info btn-sm">Details</a>
                </td>
            </tr>
        }
    </tbody>
</table>