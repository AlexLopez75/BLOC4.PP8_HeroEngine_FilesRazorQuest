@page
@model HeroEngine.Web.Pages.Heroes.CreateModel
@{
    ViewData["Title"] = "Create Hero";
}

<h2>Create a new Hero</h2>

<div class="row">
    <div class="col-md-6">
        <form method="post" class="card p-4 shadow-sm">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="mb-3">
                <label asp-for="Name" class="form-label">Hero name</label>
                <input asp-for="Name" class="form-control" placeholder="Ex: Grog the Barbarian" />
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="SelectedClass" class="form-label">Class</label>
                <select asp-for="SelectedClass" id="classSelect" class="form-select">
                    <option value="">-- Select a class --</option>
                    @foreach (var classe in Model.AvailableClasses)
                    {
                        <option value="@classe">@classe</option>
                    }
                </select>
                <span asp-validation-for="SelectedClass" class="text-danger"></span>
            </div>

            <div id="warriorFields" class="mb-3" style="display:none;">
                <label class="form-label">Battle Cry</label>
                <input asp-for="BattleCry" class="form-control" placeholder="Ex: ¡Hyaaaa!" />
            </div>

            <div id="rogueFields" class="mb-3" style="display:none;">
                <label class="form-label">Number of daggesrs</label>
                <input asp-for="NumDaggers" type="number" class="form-control" min="1" max="10" />
            </div>

            <div class="mt-4">
                <button type="submit" class="btn btn-primary">Register Hero</button>
                <a asp-page="./Index" class="btn btn-outline-secondary">Cancel</a>
            </div>
        </form>
    </div>

    <div class="col-md-6">
        <div class="alert alert-info">
            <h5>Forge Master's Advice</h5>
            <p>Choose the name and class wisely. Each class has unique abilities that you can see on the details screen once created.</p>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Function to show/hide fields based on the selected class
        document.getElementById("classSelect").addEventListener("change", function () {
            const selectedClass = this.value;
            
            // Hide all fields first
            document.getElementById("warriorFields").style.display = "none";
            document.getElementById("rogueFields").style.display = "none";

            // Show the corresponding fields
            if (selectedClass === "Warrior") {
                document.getElementById("warriorFields").style.display = "block";
            } else if (selectedClass === "Rogue") {
                document.getElementById("rogueFields").style.display = "block";
            }
        });
    </script>
}