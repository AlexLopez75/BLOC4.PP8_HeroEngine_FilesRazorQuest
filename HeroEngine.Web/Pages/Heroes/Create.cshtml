@page
@model HeroEngine.Web.Pages.Heroes.CreateModel
@{
    ViewData["Title"] = "Create Hero";
}

<h2>Create a new Hero</h2>

<div class="row">
    <div class="col-md-6">
        <form method="post" class="card p-4 shadow-sm">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="mb-3">
                <label asp-for="Name" class="form-label">Nom de l'Heroi</label>
                <input asp-for="Name" class="form-control" placeholder="Ex: Grog el Bàrbar" />
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="SelectedClass" class="form-label">Classe</label>
                <select asp-for="SelectedClass" class="form-select">
                    <option value="">-- Selecciona una classe --</option>
                    @foreach (var classe in Model.AvailableClasses)
                    {
                        <option value="@classe">@classe</option>
                    }
                </select>
                <span asp-validation-for="SelectedClass" class="text-danger"></span>
            </div>

            <div class="mt-4">
                <button type="submit" class="btn btn-primary">Register Hero</button>
                <a asp-page="./Index" class="btn btn-outline-secondary">Cancel</a>
            </div>
        </form>
    </div>

    <div class="col-md-6">
        <div class="alert alert-info">
            <h5>Forge Master's Advice</h5>
            <p>Choose the name and class wisely. Each class has unique abilities that you can see on the details screen once created.</p>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}